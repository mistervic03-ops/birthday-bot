# Slack bot token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...

# Slack app-level token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-...

# Postgres connection URL
DATABASE_URL=postgresql://user:password@localhost:5432/birthday_bot

# Birthday announcement channel ID
BIRTHDAY_CHANNEL_ID=C012345ABC

# HR Excel file path (absolute path or project-root relative path)
HR_EXCEL_PATH=./직원명부.xlsx

# Optional: extra Slack user IDs with admin command access, comma-separated
ADMIN_USER_IDS=
