# Slack bot token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...

# Slack app-level token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-...

# Postgres connection URL
DATABASE_URL=postgresql://birthday_bot:password@localhost:5432/birthday_bot

# Birthday announcement channel ID
BIRTHDAY_CHANNEL_ID=C012345ABC

# Runtime timezone used for scheduler and "today" calculations
TIMEZONE=Asia/Seoul

# HR Excel file path (Spark production path shown)
HR_EXCEL_PATH=/home/bigxdata/birthday-bot/data/hr_birthdays.xlsx

# Optional: extra Slack user IDs with admin command access, comma-separated
ADMIN_USER_IDS=
